# Path to your Obsidian vault on the host machine (absolute path)
VAULT_PATH=/Users/yourname/Documents/ObsidianVault

# LM Studio — runs on host, not in Docker
# Start LM Studio, load an embedding model (e.g. nomic-embed-text), enable server
LM_STUDIO_URL=http://host.docker.internal:1234/v1
EMBEDDING_MODEL=nomic-embed-text
# Dimension must match the model you load in LM Studio
# nomic-embed-text=768, all-minilm-l6-v2=384, mxbai-embed-large=1024
EMBEDDING_DIM=768

# Qdrant (internal Docker network URL, don't change)
QDRANT_URL=http://localhost:55333
COLLECTION_NAME=obsidian_vault

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# MCP server port (exposed to host, used by Claude Code)
MCP_PORT=55000
