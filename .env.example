# Absolute path to your Obsidian vault on the host machine
VAULT_PATH=/Users/yourname/Documents/ObsidianVault

# Where to persist the Qdrant index (mounted as a Docker volume)
# Change this if you want to use a different named volume or host path
DATA_PATH=/obsidian-mcp-data

# Embedding model (fastembed ONNX, runs fully local — no API key needed)
# The model is baked into the production image; cached in a volume for dev
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# Base collection name — actual collection is <COLLECTION_NAME>__<model_slug>
# Switching models automatically creates a separate collection
COLLECTION_NAME=obsidian_vault

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# How often the vault watcher polls for changes (seconds)
OBSERVER_INTERVAL=1.0
