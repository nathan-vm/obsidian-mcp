# Path to your Obsidian vault on the host machine (absolute path)
VAULT_PATH=/Users/yourname/Documents/ObsidianVault

# Embedding provider: lm_studio | openai | gemini
EMBEDDING_PROVIDER=lm_studio
EMBEDDING_MODEL=nomic-embed-text

# LM Studio — used when EMBEDDING_PROVIDER=lm_studio
# Start LM Studio, load an embedding model, enable the local server
LM_STUDIO_URL=http://host.docker.internal:1234/v1

# API keys — set the one matching your chosen provider
# OPENAI_API_KEY=sk-...        # provider=openai, e.g. model=text-embedding-3-small
# GEMINI_API_KEY=AIza...       # provider=gemini, e.g. model=models/text-embedding-004

# Qdrant (internal Docker network URL, don't change unless self-hosting externally)
QDRANT_URL=http://localhost:55333
# Base collection name — actual name will be <COLLECTION_NAME>__<model_slug>
# so switching models automatically creates a separate collection
COLLECTION_NAME=obsidian_vault

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# MCP server port (exposed to host, used by Claude Code)
MCP_PORT=55000

# How often the vault watcher polls for changes (seconds)
OBSERVER_INTERVAL=1.0
